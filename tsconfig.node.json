{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out/main",
    "baseUrl": ".",
    "paths": {
      "@main/*": ["electron/main/*"],
      "@shared/*": ["electron/shared/*"]
    }
  },
  "include": [
    "electron/main/**/*",
    "electron/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist"
  ]
}
