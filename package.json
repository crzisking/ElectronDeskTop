{
  "name": "ichiaDesktop",
  "version": "1.6.2",
  "description": "ichiaDesktop",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "release:win": "npm run build && electron-builder --win --publish never",
    "release:mac": "npm run build && electron-builder --mac --publish never",
    "release:linux": "npm run build && electron-builder --linux --publish never",
    "preview": "electron-vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "electron-builder install-app-deps",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.2",
    "@antv/x6": "^3.1.7",
    "@element-plus/icons-vue": "^2.3.0",
    "@microsoft/signalr": "^10.0.0",
    "@vueup/vue-quill": "^1.2.0",
    "ai": "^7.0.9",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.10.0",
    "dompurify": "^3.4.2",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.1.0",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.4.0",
    "highlight.js": "^11.11.1",
    "jwt-decode": "^4.0.0",
    "markdown-it": "^14.2.0",
    "openai": "^6.39.0",
    "pinia": "^2.1.0",
    "vue": "^3.3.0",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.2.0",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/test-utils": "^2.4.11",
    "cac": "^7.0.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^14.12.3",
    "jimp": "^0.22.12",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.1",
    "unplugin-auto-import": "^0.17.0",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.12"
  },
  "build": {
    "appId": "com.ichia.desktop.client",
    "productName": "ichiaDesktop",
    "copyright": "Copyright © 2026 Ichia",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icons/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "resources/icons/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-setup.${ext}",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://192.168.120.135:10001/",
        "channel": "latest"
      }
    ]
  }
}
